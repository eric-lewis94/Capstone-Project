    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let text = item.json.output;\n\n  text = text\n    // Remove markdown code blocks\n    .replace(/```markdown|```/g, '')\n\n    // Remove markdown formatting symbols only\n    .replace(/[#*_>`]/g, '')\n\n    // Remove emojis\n    .replace(/[\\u{1F300}-\\u{1FAFF}]/gu, '')\n\n    // Normalize new lines/spaces\n    .replace(/\\n+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\n  return {\n    json: {\n      clean_output: text\n    }\n  };\n});"
      },
