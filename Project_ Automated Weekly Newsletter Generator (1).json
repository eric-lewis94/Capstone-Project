    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  let html = item.json.data || '';\n\n  // Remove scripts/styles\n  html = html.replace(/<script[\\s\\S]*?<\\/script>/gi, '');\n  html = html.replace(/<style[\\s\\S]*?<\\/style>/gi, '');\n  html = html.replace(/<noscript[\\s\\S]*?<\\/noscript>/gi, '');\n  html = html.replace(/<!--[\\s\\S]*?-->/g, '');\n\n  // Extract headings\n  const matches = [\n    ...html.matchAll(/<h1[^>]*>(.*?)<\\/h1>/gi),\n    ...html.matchAll(/<h2[^>]*>(.*?)<\\/h2>/gi),\n    ...html.matchAll(/<h3[^>]*>(.*?)<\\/h3>/gi)\n  ];\n\n  let headlines = matches.map(m =>\n    m[1]\n      .replace(/<[^>]+>/g, '')\n      .replace(/\\s+/g, ' ')\n      .trim()\n  );\n\n  // Remove junk\n  headlines = headlines.filter(h =>\n    h.length > 15 &&\n    h.length < 200 &&\n    !h.toLowerCase().includes('read more')\n  );\n\n  // Remove duplicates\n  headlines = [...new Set(headlines)];\n\n  return {\n    json: {\n      headlines\n    }\n  };\n});"
      },
